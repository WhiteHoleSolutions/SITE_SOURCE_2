generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?   @unique
  role          String    @default("CUSTOMER") // ADMIN or CUSTOMER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Customer specific fields
  customer      Customer?
  
  @@index([email])
  @@index([phone])
}

model Customer {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Admin notes (not visible to customer)
  adminNotes      String?
  
  // Analytics
  totalSpent      Float     @default(0)
  jobsCompleted   Int       @default(0)
  
  // Relations
  inquiries       Inquiry[]
  invoices        Invoice[]
  albumAccess     AlbumAccess[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
}

model Inquiry {
  id          String    @id @default(cuid())
  name        String
  email       String
  phone       String
  message     String
  status      String    @default("NEW") // NEW, CONTACTED, CONVERTED, CLOSED
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime  @default(now())
  
  @@index([email])
  @@index([customerId])
  @@index([status])
}

model Album {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        String      @default("PUBLIC") // PUBLIC or PRIVATE
  coverImage  String?
  order       Int         @default(0)
  
  // Relations
  media       Media[]
  access      AlbumAccess[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@index([type])
  @@index([order])
}

model Media {
  id          String    @id @default(cuid())
  albumId     String
  album       Album     @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  type        String // IMAGE or VIDEO
  url         String
  thumbnailUrl String?
  title       String?
  description String?
  order       Int       @default(0)
  
  // File details
  fileSize    Int?
  width       Int?
  height      Int?
  duration    Int?      // For videos (in seconds)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([albumId])
  @@index([type])
  @@index([order])
}

model AlbumAccess {
  id          String    @id @default(cuid())
  albumId     String
  album       Album     @relation(fields: [albumId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  permission  String    @default("VIEW") // VIEW or DOWNLOAD
  
  createdAt   DateTime  @default(now())
  
  @@unique([albumId, customerId])
  @@index([albumId])
  @@index([customerId])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  status          String        @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE, CANCELLED
  
  // Invoice details
  items           InvoiceItem[]
  subtotal        Float         @default(0)
  tax             Float         @default(0)
  total           Float         @default(0)
  
  // Payment
  paidAt          DateTime?
  revolutPaymentId String?      @unique
  paymentLink     String?       // Revolut payment link URL
  
  // Dates
  issuedAt        DateTime?
  dueDate         DateTime?
  
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([customerId])
  @@index([status])
  @@index([invoiceNumber])
}

model InvoiceItem {
  id          String    @id @default(cuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  description String
  quantity    Int       @default(1)
  unitPrice   Float
  total       Float
  
  @@index([invoiceId])
}

model BusinessInfo {
  id              String    @id @default(cuid())
  businessName    String
  abn             String?   // Australian Business Number
  acn             String?   // Australian Company Number
  address         String?
  suburb          String?
  state           String?
  postcode        String?
  country         String    @default("Australia")
  email           String?
  phone           String?
  website         String?
  logo            String?   // Logo URL
  
  // Invoice settings
  taxRate         Float     @default(10.0) // GST rate (10% in Australia)
  paymentTerms    String    @default("Net 30")
  
  // Storage settings
  diskSizeGB      Float     @default(1.0) // Persistent disk size in GB (for Render)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model BillOfSale {
  id              String    @id @default(cuid())
  billNumber      String    @unique
  
  // Transaction type
  type            String    // BOUGHT or SOLD
  
  // Seller Information
  sellerName      String
  sellerAddress   String?
  sellerPhone     String?
  sellerEmail     String?
  
  // Buyer Information
  buyerName       String
  buyerAddress    String?
  buyerPhone      String?
  buyerEmail      String?
  
  // Equipment Details
  equipmentType   String
  description     String
  serialNumber    String?
  condition       String?
  
  // Financial
  salePrice       Float
  gstIncluded     Boolean   @default(true)
  gstAmount       Float?
  
  // Date
  saleDate        DateTime
  
  notes           String?
  pdfUrl          String?   // Generated PDF URL
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([billNumber])
  @@index([type])
  @@index([saleDate])
}

model Expense {
  id              String    @id @default(cuid())
  expenseNumber   String    @unique
  
  description     String
  category        String    // e.g., "Equipment", "Travel", "Supplies", "Software", etc.
  amount          Float
  gstAmount       Float?
  
  vendor          String?   // Who it was paid to
  paymentMethod   String?   // Cash, Card, Bank Transfer, etc.
  
  expenseDate     DateTime
  
  // Receipt
  receiptUrl      String?   // Uploaded receipt image/PDF
  
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([category])
  @@index([expenseDate])
  @@index([expenseNumber])
}
